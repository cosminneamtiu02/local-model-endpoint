# Normalize line endings
* text=auto eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary

# Generated files — diff but do not merge
apps/backend/app/exceptions/_generated/** linguist-generated=true

# Lock files
apps/backend/uv.lock linguist-generated=true -diff
