# All settings have defaults in app/core/config.py.
# This file is reference only — copy to .env and override as needed.
# pydantic-settings loads from this file because the runtime cwd is
# apps/backend/ (per `task dev`); a root-level .env is unreachable.

# APP_ENV: one of development | test | production
APP_ENV=development

# LOG_LEVEL: one of debug | info | warning | error | critical
LOG_LEVEL=info

# LIP-prefixed to disambiguate from Ollama daemon's own OLLAMA_HOST env
# var. The daemon and the LIP backend each read distinct variables.
# Validated to be localhost / RFC1918 / link-local unless
# ALLOW_EXTERNAL_OLLAMA is set — see below.
LIP_OLLAMA_HOST=http://localhost:11434

# Escape hatch for pointing Ollama at a non-private host (cloud
# endpoint, gateway, etc.). Default false; the validator rejects
# non-private hosts unless this is explicitly true.
# ALLOW_EXTERNAL_OLLAMA=false

# Bind interface and port for `python -m app` / `task dev`. Defaults to
# localhost only — see ALLOW_PUBLIC_BIND below before binding to a
# LAN-reachable interface like 0.0.0.0.
BIND_HOST=127.0.0.1
BIND_PORT=8000

# Escape hatch for binding to a public interface (0.0.0.0 / ::).
# Default is false (rejected by validator). Only set explicitly when
# wiring up local-network consumer access; the service has no auth.
# ALLOW_PUBLIC_BIND=false
