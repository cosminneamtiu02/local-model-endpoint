# All settings have defaults in app/core/config.py.
# This file is reference only — copy to .env and override as needed.
# pydantic-settings loads from this file because the runtime cwd is
# apps/backend/ (per `task dev`); a root-level .env is unreachable.
#
# Every Settings field is read from a `LIP_`-prefixed env var so a single
# shell can run both the Ollama daemon (which reads `OLLAMA_HOST`) and
# LIP without crossed wires.
#
# Empty values (e.g. KEY=) are treated as unset due to env_ignore_empty=True.
#
# When you create the runtime .env, restrict its permissions:
#   cp .env.example .env && chmod 600 .env
# .env is gitignored. No Settings field today is a SecretStr — when one
# is added (e.g. an Ollama auth token for a future hosted endpoint), it
# MUST use ``pydantic.SecretStr`` so the value never reaches stdout via
# ``logger.info("app_startup", ...settings...)``.

# LIP_APP_ENV: one of development | test | production
LIP_APP_ENV=development

# LIP_LOG_LEVEL: one of debug | info | warning | error | critical
LIP_LOG_LEVEL=info

# Ollama daemon URL. The `LIP_` prefix disambiguates from Ollama's own
# `OLLAMA_HOST` env var. Validated to be localhost / RFC1918 /
# link-local unless `LIP_ALLOW_EXTERNAL_OLLAMA=true`.
LIP_OLLAMA_HOST=http://localhost:11434

# Escape hatch for pointing Ollama at a non-private host (cloud
# endpoint, gateway, etc.). Default false; the validator rejects
# non-private hosts unless this is explicitly true. Listed uncommented
# with the safe default so a `grep -E '^LIP_'` finds every Settings
# field at the same time.
LIP_ALLOW_EXTERNAL_OLLAMA=false

# Bind interface and port for `python -m app` / `task dev`. Defaults to
# localhost only — see LIP_ALLOW_PUBLIC_BIND below before binding to a
# LAN-reachable interface like 0.0.0.0.
LIP_BIND_HOST=127.0.0.1
LIP_BIND_PORT=8000

# Escape hatch for binding to a public interface (0.0.0.0 / ::).
# Default is false (rejected by validator). Only set explicitly when
# wiring up local-network consumer access; the service has no auth.
LIP_ALLOW_PUBLIC_BIND=false
